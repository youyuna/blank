    llm_retry_padding_seconds = llm_retry_padding_seconds,
    llm_fallback_models = llm_fallback_models
  )

  list(
    alpha_result = alpha_result,
    beta_result = beta_result,
    tax_result = tax_result,
    integrated_result = integrated_result
  )
}


