microassist_generate_integrated_figures <- function(alpha_result,
                                                    beta_result,
                                                    taxonomic_result,
                                                    output_dir = ".",
                                                    prefix = "microassist_integrated") {
  dir.create(output_dir, showWarnings = FALSE, recursive = TRUE)
  stamp <- format(Sys.time(), "%Y%m%d_%H%M%S")
  out <- c()

  # Figure 1: alpha diversity boxplots (Observed/Shannon/Simpson/Chao1/ACE)
  try({
    alpha_df <- alpha_result$alpha_metrics
    group_var <- alpha_result$grouping_variable
    metrics <- intersect(c("Observed", "Shannon", "Simpson", "Chao1", "ACE"), colnames(alpha_df))
    if (!is.null(group_var) && group_var %in% colnames(alpha_df) && length(metrics) > 0) {
      alpha_long <- do.call(rbind, lapply(metrics, function(m) {
        data.frame(
          metric = m,
          value = alpha_df[[m]],
          group = as.character(alpha_df[[group_var]]),
          stringsAsFactors = FALSE
        )
      }))
      p <- ggplot(alpha_long, aes(x = group, y = value, fill = group)) +
        geom_boxplot(outlier.size = 0.5) +
        facet_wrap(~metric, scales = "free_y") +
        theme_bw() +
        theme(axis.text.x = element_text(angle = 45, hjust = 1), legend.position = "none") +
        labs(title = "Alpha Diversity by Group", x = group_var, y = "Value")
      fp <- file.path(output_dir, paste0(prefix, "_alpha_", stamp, ".png"))
      ggsave(fp, p, width = 10, height = 7, dpi = 150)
      out <- c(out, fp)
    }
  }, silent = TRUE)

  # Figure 2: beta diversity ordination
  try({
    ord <- beta_result$ordination
    vec <- ord$vectors
    if (!is.null(vec)) {
      df <- as.data.frame(vec[, 1:2, drop = FALSE])
      colnames(df) <- c("Axis1", "Axis2")
      df$Sample <- rownames(df)
      if (!is.null(beta_result$group_values)) {
        grp <- beta_result$group_values
        df$Group <- as.character(grp[df$Sample])
      } else {
        df$Group <- "All"
      }
      p <- ggplot(df, aes(x = Axis1, y = Axis2, color = Group)) +
        geom_point(size = 2, alpha = 0.85) +
        theme_bw() +
        labs(title = "PCoA (Beta Diversity)", x = "Axis 1", y = "Axis 2")
      fp <- file.path(output_dir, paste0(prefix, "_beta_", stamp, ".png"))
      ggsave(fp, p, width = 7, height = 5, dpi = 150)
      out <- c(out, fp)
    }
  }, silent = TRUE)

  # Figure 3: overall top taxa bar chart
  try({
    tt <- taxonomic_result$top_table
    if (!is.null(tt) && nrow(tt) > 0) {
      tt$taxon_label[is.na(tt$taxon_label) | tt$taxon_label == ""] <- tt$taxon_id[is.na(tt$taxon_label) | tt$taxon_label == ""]
      tt <- tt[order(tt$mean_relative_abundance, decreasing = TRUE), , drop = FALSE]
      tt$taxon_label <- factor(tt$taxon_label, levels = rev(tt$taxon_label))
      p <- ggplot(tt, aes(x = taxon_label, y = mean_relative_abundance)) +
        geom_col(fill = "steelblue") +
        coord_flip() +
        theme_bw() +
        labs(title = "Overall Top Taxa Mean Relative Abundance", x = "Taxon", y = "Mean Relative Abundance")
      fp <- file.path(output_dir, paste0(prefix, "_taxa_overall_", stamp, ".png"))
      ggsave(fp, p, width = 8, height = 6, dpi = 150)
      out <- c(out, fp)
    }
  }, silent = TRUE)

  # Figure 4: top taxa by group
  try({
    gtt <- taxonomic_result$group_top_table
    gvar <- taxonomic_result$grouping_variable
    if (!is.null(gtt) && nrow(gtt) > 0 && !is.null(gvar) && gvar %in% colnames(gtt)) {
      gtt$taxon_label[is.na(gtt$taxon_label) | gtt$taxon_label == ""] <- gtt$taxon_id[is.na(gtt$taxon_label) | gtt$taxon_label == ""]
      gtt$taxon_label <- factor(gtt$taxon_label, levels = rev(unique(gtt$taxon_label)))
      p <- ggplot(gtt, aes(x = taxon_label, y = mean_relative_abundance, fill = .data[[gvar]])) +
        geom_col(position = position_dodge(width = 0.9)) +
        coord_flip() +
        facet_wrap(as.formula(paste("~", gvar)), scales = "free_y") +
        theme_bw() +
        labs(title = "Top Taxa by Group", x = "Taxon", y = "Mean Relative Abundance", fill = gvar)
      fp <- file.path(output_dir, paste0(prefix, "_taxa_by_group_", stamp, ".png"))
      ggsave(fp, p, width = 8, height = 6, dpi = 150)
      out <- c(out, fp)
    }
  }, silent = TRUE)

  out
}

microassist_choose_group_var <- function(meta_df,
                                         requested_group_var = NULL,
                                         priority_candidates = c("primaryTumorType", "SampleType", "sample_type", "group", "Group", "condition", "Condition", "Treatment", "treatment"),
                                         min_non_missing = 3,
                                         min_levels = 2,
                                         max_levels = 20) {
  if (is.null(meta_df) || nrow(meta_df) == 0 || ncol(meta_df) == 0) {
    return(NULL)
  }

  is_valid_group <- function(x) {
    keep <- !is.na(x) & x != ""
    x <- x[keep]
    if (length(x) < min_non_missing) return(FALSE)
    nlev <- length(unique(x))
    nlev >= min_levels && nlev <= max_levels
  }

  if (!is.null(requested_group_var) && requested_group_var %in% colnames(meta_df)) {
    if (is_valid_group(meta_df[[requested_group_var]])) {
      return(requested_group_var)
    }
  }

  for (cand in priority_candidates) {
    if (cand %in% colnames(meta_df) && is_valid_group(meta_df[[cand]])) {
      return(cand)
    }
  }

  for (nm in colnames(meta_df)) {
    x <- meta_df[[nm]]
    if (is.factor(x) || is.character(x) || is.logical(x)) {
      if (is_valid_group(as.character(x))) {
        return(nm)
      }
    }
  }

  NULL
}

