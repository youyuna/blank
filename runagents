microassist_beta_diversity_agent <- function(ps,
                                             experimental_context,
                                             group_var = NULL,
                                             distance_method = "bray",
                                             google_api_key = NULL,
                                             api_key_file = "~/Documents/gemini_api_key_copy.txt",
                                             model_name = "gemini-flash-latest",
                                             temperature = 0,
                                             max_output_tokens = 8192,
                                             llm_max_retries = 3,
                                             llm_retry_padding_seconds = 2,
                                             llm_fallback_models = c("gemini-1.5-flash-latest")) {
  if (!inherits(ps, "phyloseq")) stop("Input 'ps' must be a phyloseq object.")
  if (is.null(experimental_context) || nchar(experimental_context) == 0) {
    stop("Input 'experimental_context' must be a non-empty character string.")
  }

  api_key <- microassist_get_api_key(google_api_key, api_key_file)

  dist_obj <- phyloseq::distance(ps, method = distance_method)
  ord <- phyloseq::ordinate(ps, method = "PCoA", distance = dist_obj)

  otu <- as(otu_table(ps), "matrix")
  if (!taxa_are_rows(ps)) otu <- t(otu)
  taxa_variance <- apply(otu, 1, var)
  top_taxa <- sort(taxa_variance, decreasing = TRUE)[1:min(20, length(taxa_variance))]

  meta_df <- as.data.frame(sample_data(ps))
  selected_group_var <- microassist_choose_group_var(meta_df, requested_group_var = group_var)

  group_values <- NULL
  group_line <- if (!is.null(selected_group_var)) {
    group_values <- meta_df[[selected_group_var]]
    names(group_values) <- rownames(meta_df)
    paste0("Grouping variable: ", selected_group_var, "; Levels: ", paste(unique(meta_df[[selected_group_var]]), collapse = ", "))
  } else {
    "No valid grouping variable available for beta diversity grouping."
  }

  eig <- ord$values$Eigenvalues
  eig_preview <- if (!is.null(eig) && length(eig) > 0) round(eig[1:min(3, length(eig))], 6) else NA

  dvals <- as.numeric(dist_obj)
  dist_stats <- c(
    min = min(dvals, na.rm = TRUE),
    q25 = as.numeric(quantile(dvals, 0.25, na.rm = TRUE)),
    median = median(dvals, na.rm = TRUE),
    mean = mean(dvals, na.rm = TRUE),
    q75 = as.numeric(quantile(dvals, 0.75, na.rm = TRUE)),
    max = max(dvals, na.rm = TRUE)
  )

  top_taxa_small <- round(top_taxa[1:min(10, length(top_taxa))], 6)

  prompt <- paste0(
    "You are a microbiome community ecology expert. Interpret beta diversity patterns and potential drivers. ",
    "Return markdown ONLY with the exact headers:\n\n",
    "### Community Similarity and Separation\n\n",
    "### Likely Drivers (Taxa or Functions)\n\n",
    "### Community-Structure Hypotheses\n\n",
    "Context: ", experimental_context, "\n",
    group_line, "\n",
    "Distance stats (", distance_method, "): ",
    paste(names(round(dist_stats, 5)), round(dist_stats, 5), collapse = "; "), "\n",
    "Top PCoA eigenvalues: ", paste(eig_preview, collapse = ", "), "\n",
    "Top variable taxa (top 10 variance): ",
    paste(names(top_taxa_small), top_taxa_small, collapse = "; "), "\n"
  )

  headers <- c("Community Similarity and Separation", "Likely Drivers (Taxa or Functions)", "Community-Structure Hypotheses")
  sections <- microassist_safe_llm_sections(
    prompt, headers, api_key, model_name, temperature, max_output_tokens,
    max_retries = llm_max_retries,
    retry_padding_seconds = llm_retry_padding_seconds,
    fallback_models = llm_fallback_models
  )
  report_file <- microassist_write_report("microassist_beta_diversity_insights", experimental_context, sections)

  list(
    agent = "beta_diversity",
    sections = sections,
    distance_method = distance_method,
    distance = dist_obj,
    ordination = ord,
    group_values = group_values,
    top_variable_taxa = top_taxa,
    report_file = report_file
  )
}

# ------------------------------------------------------------------
# Agent 4: Taxonomic Composition Insights
# ------------------------------------------------------------------

microassist_taxonomic_composition_agent <- function(ps,
                                                    experimental_context,
                                                    rank = "Phylum",
                                                    top_n = 15,
                                                    group_var = NULL,
                                                    google_api_key = NULL,
                                                    api_key_file = "~/Documents/gemini_api_key_copy.txt",
                                                    model_name = "gemini-flash-latest",
                                                    temperature = 0,
                                                    max_output_tokens = 8192,
                                              llm_max_retries = 3,
                                              llm_retry_padding_seconds = 2,
                                              llm_fallback_models = c("gemini-1.5-flash-latest")) {
  if (!inherits(ps, "phyloseq")) stop("Input 'ps' must be a phyloseq object.")
  if (is.null(experimental_context) || nchar(experimental_context) == 0) {
    stop("Input 'experimental_context' must be a non-empty character string.")
  }

  api_key <- microassist_get_api_key(google_api_key, api_key_file)

  if (!(rank %in% rank_names(ps))) {
    stop("Requested rank '", rank, "' not found. Available ranks: ", paste(rank_names(ps), collapse = ", "))
  }

  meta_df <- as.data.frame(sample_data(ps))
  selected_group_var <- microassist_choose_group_var(meta_df, requested_group_var = group_var)

  ps_rel <- microbiome::transform(ps, "compositional")
  ps_rank <- phyloseq::tax_glom(ps_rel, taxrank = rank, NArm = FALSE)

  otu_rank <- as(otu_table(ps_rank), "matrix")
  if (!taxa_are_rows(ps_rank)) otu_rank <- t(otu_rank)

  mean_abundance <- rowMeans(otu_rank, na.rm = TRUE)
  top_abundance <- sort(mean_abundance, decreasing = TRUE)[1:min(top_n, length(mean_abundance))]

  taxa_df <- as.data.frame(tax_table(ps_rank))
  ids <- names(top_abundance)
  labels <- taxa_df[ids, rank, drop = TRUE]

  top_table <- data.frame(
    taxon_id = ids,
    taxon_label = as.character(labels),
    mean_relative_abundance = as.numeric(top_abundance),
    stringsAsFactors = FALSE
  )

  group_top_table <- data.frame()
  group_summary <- "No valid grouping variable available for group-level taxonomic analysis."
  if (!is.null(selected_group_var) && selected_group_var %in% colnames(meta_df)) {
    aligned_group <- as.character(meta_df[rownames(otu_rank), selected_group_var, drop = TRUE])
    group_levels <- unique(aligned_group[!is.na(aligned_group) & aligned_group != ""])

    group_tables <- lapply(group_levels, function(gl) {
      idx <- aligned_group == gl
      grp_mean <- rowMeans(otu_rank[, idx, drop = FALSE], na.rm = TRUE)
      grp_top <- sort(grp_mean, decreasing = TRUE)[1:min(top_n, length(grp_mean))]
      grp_ids <- names(grp_top)
      grp_labels <- taxa_df[grp_ids, rank, drop = TRUE]
      data.frame(
        group = gl,
        taxon_id = grp_ids,
        taxon_label = as.character(grp_labels),
        mean_relative_abundance = as.numeric(grp_top),
        stringsAsFactors = FALSE
      )
    })

    group_top_table <- do.call(rbind, group_tables)
    if (!is.null(group_top_table) && nrow(group_top_table) > 0) {
      colnames(group_top_table)[colnames(group_top_table) == "group"] <- selected_group_var
      group_summary <- paste(capture.output(print(utils::head(group_top_table, 30))), collapse = "\n")
    }
  }
  
  prompt <- paste0(
    "You are a microbiome taxonomy expert. Interpret composition and prioritize targets for follow-up. ",
    "Return markdown ONLY with the exact headers:\n\n",
    "### Dominant Taxa and Biological Roles\n\n",
    "### Group-Level Taxonomic Differences\n\n",
    "### Priority Microbes for Follow-Up\n\n",
    "Context:\n", experimental_context, "\n\n",
    "Taxonomic rank analyzed: ", rank, "\n",
    "Overall top taxa table:\n", paste(capture.output(print(top_table)), collapse = "\n"), "\n\n",
    "Grouping variable used: ", ifelse(is.null(selected_group_var), "None", selected_group_var), "\n",
    "Group-level top taxa preview:\n", group_summary, "\n"
  )

  headers <- c("Dominant Taxa and Biological Roles", "Group-Level Taxonomic Differences", "Priority Microbes for Follow-Up")
  sections <- microassist_safe_llm_sections(
    prompt, headers, api_key, model_name, temperature, max_output_tokens,
    max_retries = llm_max_retries,
    retry_padding_seconds = llm_retry_padding_seconds,
    fallback_models = llm_fallback_models
  )
  report_file <- microassist_write_report("microassist_taxonomic_composition_insights", experimental_context, sections)

  list(
    agent = "taxonomic_composition",
    sections = sections,
    rank = rank,
    grouping_variable = selected_group_var,
    top_table = top_table,
    group_top_table = group_top_table,
    report_file = report_file
  )
}

# ------------------------------------------------------------------
# Agent 5: Integrated Analysis Report
# ------------------------------------------------------------------

microassist_integrated_report_agent <- function(experimental_context,
                                                preprocessing_result,
                                                group_var = NULL,
                                                alpha_result,
                                                beta_result,
                                                taxonomic_result,
                                                google_api_key = NULL,
                                                api_key_file = "~/Documents/gemini_api_key_copy.txt",
                                                model_name = "gemini-flash-latest",
                                                temperature = 0,
                                                max_output_tokens = 8192,
                                                figure_output_dir = ".",
                                                preprocessing_report_file = NULL,
                                                llm_max_retries = 3,
                                                llm_retry_padding_seconds = 2,
                                              llm_fallback_models = c("gemini-1.5-flash-latest")) {
  if (is.null(experimental_context) || nchar(experimental_context) == 0) {
    stop("Input 'experimental_context' must be a non-empty character string.")
  }

  api_key <- microassist_get_api_key(google_api_key, api_key_file)

  obj_preview <- function(x) paste(capture.output(str(x, max.level = 2)), collapse = "\n")

  prompt <- paste0(
    "You are generating a final microbiome analysis report for a biology team. ",
    "Return markdown ONLY with the exact headers:\n\n",
    "### Executive Summary\n\n",
    "### Cross-Analysis Synthesis\n\n",
    "### Actionable Biological Hypotheses\n\n",
    "### Recommended Validation Experiments\n\n",
    "Context:\n", experimental_context, "\n\n",
    "Preprocessing output preview:\n", obj_preview(preprocessing_result), "\n\n",
    "Alpha output preview:\n", obj_preview(alpha_result), "\n\n",
    "Beta output preview:\n", obj_preview(beta_result), "\n\n",
    "Taxonomic output preview:\n", obj_preview(taxonomic_result), "\n"
  )

  headers <- c("Executive Summary", "Cross-Analysis Synthesis", "Actionable Biological Hypotheses", "Recommended Validation Experiments")
  sections <- microassist_safe_llm_sections(
    prompt, headers, api_key, model_name, temperature, max_output_tokens,
    max_retries = llm_max_retries,
    retry_padding_seconds = llm_retry_padding_seconds,
    fallback_models = llm_fallback_models
  )

  previous_report_sections <- microassist_build_previous_report_sections(
    preprocessing_result = preprocessing_result,
    alpha_result = alpha_result,
    beta_result = beta_result,
    taxonomic_result = taxonomic_result,
    preprocessing_report_file = preprocessing_report_file
  )
  combined_sections <- c(sections, previous_report_sections)

  report_file_txt <- microassist_write_report("microassist_integrated_analysis_report", experimental_context, combined_sections)

  figure_paths <- microassist_generate_integrated_figures(
    alpha_result = alpha_result,
    beta_result = beta_result,
    taxonomic_result = taxonomic_result,
    output_dir = figure_output_dir,
    prefix = "microassist_integrated"
  )

  report_file_html <- microassist_write_html_report(
    prefix = "microassist_integrated_analysis_report",
    context = experimental_context,
    sections = combined_sections,
    figure_paths = figure_paths
  )

  list(
    agent = "integrated_report",
    sections = sections,
    embedded_agent_reports = previous_report_sections,
    report_file = report_file_txt,
    report_file_html = report_file_html,
    figure_files = figure_paths
  )
}

