microassist_get_api_key <- function(google_api_key = NULL,
                                    api_key_file = "~/Documents/gemini_api_key_copy.txt") {
  resolved_file <- path.expand(api_key_file)

  if (!is.null(api_key_file) && file.exists(resolved_file)) {
    api_key <- readLines(resolved_file, n = 1, warn = FALSE)
    if (nchar(api_key) == 0) {
      stop("API key file '", resolved_file, "' is empty.")
    }
    return(api_key)
  }

  if (!is.null(google_api_key) && nchar(google_api_key) > 0) {
    return(google_api_key)
  }

  stop("Either 'google_api_key' or a valid 'api_key_file' must be provided.")
}

microassist_call_gemini <- function(final_prompt_text,
                                    api_key,
                                    model_name = "gemini-flash-latest",
                                    temperature = 0,
                                    max_output_tokens = 8192) {
  api_endpoint_url <- paste0(
    "https://generativelanguage.googleapis.com/v1beta/models/",
    model_name,
    ":generateContent"
  )

  request_body <- list(
    contents = list(list(parts = list(list(text = final_prompt_text)))),
    generationConfig = list(
      temperature = temperature,
      maxOutputTokens = max_output_tokens
    )
  )

  response <- tryCatch({
    httr::POST(
      url = api_endpoint_url,
      httr::add_headers(.headers = c("Content-Type" = "application/json")),
      query = list(key = api_key),
      body = RJSONIO::toJSON(request_body, auto_unbox = TRUE),
      encode = "json"
    )
  }, error = function(e) {
    stop(paste("Google Gemini API call failed:", e$message), call. = FALSE)
  })

  if (httr::http_error(response)) {
    response_text <- httr::content(response, "text")
    stop(
      paste0(
        "Google Gemini API request failed with status ",
        httr::status_code(response),
        ". Response: ",
        response_text
      ),
      call. = FALSE
    )
  }

  response_content <- httr::content(response, "parsed")

  if (is.null(response_content$candidates) || length(response_content$candidates) == 0) {
    stop("No valid candidates found in LLM response.", call. = FALSE)
  }

  parts <- response_content$candidates[[1]]$content$parts
  if (is.null(parts) || length(parts) == 0) {
    stop("LLM response candidates found, but content/parts are missing.", call. = FALSE)
  }

  part_texts <- sapply(parts, function(part) if (!is.null(part$text)) part$text else NA_character_)
  llm_text <- paste(na.omit(part_texts), collapse = "\n")

  if (nchar(llm_text) == 0) {
    stop("LLM response was received but contained no extractable text.", call. = FALSE)
  }

  llm_text
}


microassist_parse_retry_seconds <- function(error_message,
                                            default_seconds = 20) {
  retry_seconds <- NA_real_

  m1 <- regmatches(error_message, regexec("retry in ([0-9]+(?:\\.[0-9]+)?)s", error_message, ignore.case = TRUE))
  if (length(m1) > 0 && length(m1[[1]]) > 1) {
    retry_seconds <- suppressWarnings(as.numeric(m1[[1]][2]))
  }

  if (is.na(retry_seconds)) {
    m2 <- regmatches(error_message, regexec('\"retryDelay\"\\s*:\\s*\"([0-9]+)s\"', error_message, perl = TRUE))
    if (length(m2) > 0 && length(m2[[1]]) > 1) {
      retry_seconds <- suppressWarnings(as.numeric(m2[[1]][2]))
    }
  }

  if (is.na(retry_seconds) || retry_seconds <= 0) {
    retry_seconds <- default_seconds
  }

  retry_seconds
}

microassist_call_gemini_with_retry <- function(final_prompt_text,
                                               api_key,
                                               model_name = "gemini-flash-latest",
                                               temperature = 0,
                                               max_output_tokens = 8192,
                                               max_retries = 3,
                                               retry_padding_seconds = 2,
                                               fallback_models = c("gemini-1.5-flash-latest")) {
  model_candidates <- unique(c(model_name, fallback_models))
  last_error_message <- NULL

  for (model_i in seq_along(model_candidates)) {
    this_model <- model_candidates[[model_i]]
    attempt <- 1

    while (attempt <= (max_retries + 1)) {
      out <- tryCatch({
        microassist_call_gemini(
          final_prompt_text = final_prompt_text,
          api_key = api_key,
          model_name = this_model,
          temperature = temperature,
          max_output_tokens = max_output_tokens
        )
      }, error = function(e) e)

      if (!inherits(out, "error")) {
        if (this_model != model_name) {
          message("Gemini call succeeded using fallback model: ", this_model)
        }
        return(out)
      }

      msg <- conditionMessage(out)
      last_error_message <- msg
      is_quota_error <- grepl("status 429|RESOURCE_EXHAUSTED|rate-limits|quota", msg, ignore.case = TRUE)

      if (!is_quota_error) {
        stop(msg, call. = FALSE)
      }

      if (attempt <= max_retries) {
        wait_seconds <- microassist_parse_retry_seconds(msg) + retry_padding_seconds
        message("Gemini quota/rate limit for model ", this_model,
                " (attempt ", attempt, "/", max_retries + 1,
                "). Waiting ", round(wait_seconds, 1), " seconds before retry...")
        Sys.sleep(wait_seconds)
        attempt <- attempt + 1
      } else {
        break
      }
    }

    if (model_i < length(model_candidates)) {
      message("Switching to fallback model after quota retries: ", model_candidates[[model_i + 1]])
      Sys.sleep(2)
    }
  }

  stop(last_error_message, call. = FALSE)
}

microassist_extract_markdown_sections <- function(text, headers) {
  out <- list()
  for (i in seq_along(headers)) {
    h <- headers[[i]]
    h_next <- if (i < length(headers)) headers[[i + 1]] else NULL

    pattern <- if (is.null(h_next)) {
      paste0("(?s)### ", h, "\\n\\n(.*)$")
    } else {
      paste0("(?s)### ", h, "\\n\\n(.*?)(?:\\n\\n### ", h_next, "|$)")
    }

    m <- regmatches(text, regexec(pattern, text, perl = TRUE, ignore.case = TRUE))
    if (length(m) > 0 && length(m[[1]]) > 1) {
      out[[h]] <- trimws(m[[1]][2])
    } else {
      out[[h]] <- paste0("Error: Could not parse section '", h, "'.")
    }
  }
  out
}

microassist_write_report <- function(prefix, context, sections) {
  timestamp <- format(Sys.time(), "%Y%m%d_%H%M%S")
  filename <- paste0(prefix, "_", timestamp, ".txt")

  section_text <- paste(vapply(names(sections), function(h) {
    paste0("### ", h, "\n", sections[[h]])
  }, character(1)), collapse = "\n\n")

  full_text <- paste0(
    "Timestamp: ", format(Sys.time(), "%Y-%m-%d %H:%M:%S"), "\n\n",
    "--- Experimental Context ---\n", context, "\n\n",
    section_text, "\n"
  )

  writeLines(full_text, filename)
  message("Saved report: ", filename)
  filename
}

microassist_write_html_report <- function(prefix,
                                          context,
                                          sections,
                                          figure_paths = character(0)) {
  timestamp <- format(Sys.time(), "%Y%m%d_%H%M%S")
  filename <- paste0(prefix, "_", timestamp, ".html")

  esc <- function(x) {
    x <- gsub("&", "&amp;", x, fixed = TRUE)
    x <- gsub("<", "&lt;", x, fixed = TRUE)
    x <- gsub(">", "&gt;", x, fixed = TRUE)
    x
  }

  section_html <- paste(vapply(names(sections), function(h) {
    body <- esc(sections[[h]])
    body <- gsub("\n", "<br/>", body)
    paste0("<section><h3>", esc(h), "</h3><p>", body, "</p></section>")
  }, character(1)), collapse = "\n")

  figure_html <- ""
  if (length(figure_paths) > 0) {
    figure_blocks <- vapply(seq_along(figure_paths), function(i) {
      fp <- figure_paths[[i]]
      paste0(
        "<figure><img src=\"", fp, "\" alt=\"Integrated Figure ", i,
        "\" style=\"max-width: 100%; height: auto;\"/><figcaption>Integrated Figure ",
        i, "</figcaption></figure>"
      )
    }, character(1))
    figure_html <- paste0("<h2>Figures</h2>\n", paste(figure_blocks, collapse = "\n"))
  }

  html <- paste0(
    "<!doctype html><html><head><meta charset=\"utf-8\"/>",
    "<title>Integrated Microbiome Analysis Report</title>",
    "<style>body{font-family:Arial,sans-serif;max-width:1000px;margin:40px auto;line-height:1.5;padding:0 16px;}h1,h2,h3{color:#1f2937;}section{margin-bottom:24px;}figure{margin:20px 0;}figcaption{color:#4b5563;font-size:0.9em;}code{background:#f3f4f6;padding:2px 4px;border-radius:4px;}</style>",
    "</head><body>",
    "<h1>Integrated Microbiome Analysis Report</h1>",
    "<p><strong>Timestamp:</strong> ", format(Sys.time(), "%Y-%m-%d %H:%M:%S"), "</p>",
    "<h2>Experimental Context</h2><p>", esc(context), "</p>",
    section_html,
    figure_html,
    "</body></html>"
  )

  writeLines(html, filename)
  message("Saved HTML report: ", filename)
  filename
}

microassist_safe_llm_sections <- function(prompt,
                                          headers,
                                          api_key,
                                          model_name,
                                          temperature,
                                          max_output_tokens,
                                          max_retries = 3,
                                          retry_padding_seconds = 2,
                                          fallback_models = c("gemini-1.5-flash-latest")) {
  tryCatch({
    llm_text <- microassist_call_gemini_with_retry(
      final_prompt_text = prompt,
      api_key = api_key,
      model_name = model_name,
      temperature = temperature,
      max_output_tokens = max_output_tokens,
      max_retries = max_retries,
      retry_padding_seconds = retry_padding_seconds,
      fallback_models = fallback_models
    )
    microassist_extract_markdown_sections(llm_text, headers)
  }, error = function(e) {
    fallback <- as.list(rep("", length(headers)))
    names(fallback) <- headers
    fallback[[headers[[1]]]] <- paste0("LLM call failed after retries; generated fallback report content. Error: ", e$message)
    if (length(headers) > 1) {
      for (h in headers[-1]) {
        fallback[[h]] <- "No LLM output available due to upstream error."
      }
    }
    fallback
  })
}

microassist_read_report_file <- function(result_obj,
                                        fallback_label = "Unknown Agent",
                                        report_prefix = NULL,
                                        explicit_report_file = NULL) {
  report_path <- NULL

  if (!is.null(explicit_report_file) && file.exists(explicit_report_file)) {
    report_path <- explicit_report_file
  } else if (!is.null(result_obj$report_file) && file.exists(result_obj$report_file)) {
    report_path <- result_obj$report_file
  } else if (!is.null(report_prefix)) {
    candidates <- Sys.glob(paste0(report_prefix, "_*.txt"))
    if (length(candidates) > 0) {
      info <- file.info(candidates)
      report_path <- rownames(info)[which.max(info$mtime)]
    }
  }

  if (is.null(report_path) || !file.exists(report_path)) {
    return(paste0("Report file unavailable for ", fallback_label, "."))
  }

  paste(readLines(report_path, warn = FALSE), collapse = "\n")
}

