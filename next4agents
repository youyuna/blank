    "Alpha output:\n", safe_capture(alpha_output), "\n\n",
    "Beta output:\n", safe_capture(beta_output), "\n\n",
    "Taxonomic output:\n", safe_capture(taxonomic_output), "\n"
  )

  llm_text <- microassist_call_gemini(prompt, api_key, model_name, temperature, max_output_tokens)
  sections <- microassist_extract_sections(
    llm_text,
    c("Executive Summary", "Cross-Analysis Synthesis", "Actionable Biological Hypotheses", "Suggested Validation and Next Analyses")
  )

  body <- paste0(
    "--- Integrated Microbiome Analysis Report ---\n\n",
    "### Executive Summary\n", sections[["Executive Summary"]], "\n\n",
    "### Cross-Analysis Synthesis\n", sections[["Cross-Analysis Synthesis"]], "\n\n",
    "### Actionable Biological Hypotheses\n", sections[["Actionable Biological Hypotheses"]], "\n\n",
    "### Suggested Validation and Next Analyses\n", sections[["Suggested Validation and Next Analyses"]]
  )

  report_file <- microassist_save_report("microassist_integrated_analysis_report", experimental_context, body)

  list(report_sections = sections, report_file = report_file)
}

