microassist_generate_integrated_figures <- function(alpha_result,
                                                    beta_result,
                                                    taxonomic_result,
                                                    output_dir = ".",
                                                    prefix = "microassist_integrated") {
  dir.create(output_dir, showWarnings = FALSE, recursive = TRUE)
  stamp <- format(Sys.time(), "%Y%m%d_%H%M%S")
  out <- c()

  # Figure 1: alpha diversity boxplots (Observed/Shannon/Simpson/Chao1/ACE)
  try({
    alpha_df <- alpha_result$alpha_metrics
    group_var <- alpha_result$grouping_variable
    metrics <- intersect(c("Observed", "Shannon", "Simpson", "Chao1", "ACE"), colnames(alpha_df))
    if (!is.null(group_var) && group_var %in% colnames(alpha_df) && length(metrics) > 0) {
      alpha_long <- do.call(rbind, lapply(metrics, function(m) {
        data.frame(
          metric = m,
          value = alpha_df[[m]],
          group = as.character(alpha_df[[group_var]]),
          stringsAsFactors = FALSE
        )
      }))
      p <- ggplot(alpha_long, aes(x = group, y = value, fill = group)) +
        geom_boxplot(outlier.size = 0.5) +
        facet_wrap(~metric, scales = "free_y") +
        theme_bw() +
        theme(axis.text.x = element_text(angle = 45, hjust = 1), legend.position = "none") +
        labs(title = "Alpha Diversity by Group", x = group_var, y = "Value")
      fp <- file.path(output_dir, paste0(prefix, "_alpha_", stamp, ".png"))
      ggsave(fp, p, width = 10, height = 7, dpi = 150)
      out <- c(out, fp)
    }
  }, silent = TRUE)

  # Figure 2: beta diversity ordination
  try({
    ord <- beta_result$ordination
    vec <- ord$vectors
    if (!is.null(vec)) {
      df <- as.data.frame(vec[, 1:2, drop = FALSE])
      colnames(df) <- c("Axis1", "Axis2")
      df$Sample <- rownames(df)
      if (!is.null(beta_result$group_values)) {
        grp <- beta_result$group_values
        df$Group <- as.character(grp[df$Sample])
      } else {
        df$Group <- "All"
      }
      p <- ggplot(df, aes(x = Axis1, y = Axis2, color = Group)) +
        geom_point(size = 2, alpha = 0.85) +
        theme_bw() +
        labs(title = "PCoA (Beta Diversity)", x = "Axis 1", y = "Axis 2")
      fp <- file.path(output_dir, paste0(prefix, "_beta_", stamp, ".png"))
      ggsave(fp, p, width = 7, height = 5, dpi = 150)
      out <- c(out, fp)
    }
  }, silent = TRUE)

  # Figure 3: overall top taxa bar chart
  try({
    tt <- taxonomic_result$top_table
    if (!is.null(tt) && nrow(tt) > 0) {
      tt$taxon_label[is.na(tt$taxon_label) | tt$taxon_label == ""] <- tt$taxon_id[is.na(tt$taxon_label) | tt$taxon_label == ""]
      tt <- tt[order(tt$mean_relative_abundance, decreasing = TRUE), , drop = FALSE]
      tt$taxon_label <- factor(tt$taxon_label, levels = rev(tt$taxon_label))
      p <- ggplot(tt, aes(x = taxon_label, y = mean_relative_abundance)) +
        geom_col(fill = "steelblue") +
        coord_flip() +
        theme_bw() +
        labs(title = "Overall Top Taxa Mean Relative Abundance", x = "Taxon", y = "Mean Relative Abundance")
      fp <- file.path(output_dir, paste0(prefix, "_taxa_overall_", stamp, ".png"))
      ggsave(fp, p, width = 8, height = 6, dpi = 150)
      out <- c(out, fp)
    }
  }, silent = TRUE)

  # Figure 4: top taxa by group
  try({
    gtt <- taxonomic_result$group_top_table
    gvar <- taxonomic_result$grouping_variable
    if (!is.null(gtt) && nrow(gtt) > 0 && !is.null(gvar) && gvar %in% colnames(gtt)) {
      gtt$taxon_label[is.na(gtt$taxon_label) | gtt$taxon_label == ""] <- gtt$taxon_id[is.na(gtt$taxon_label) | gtt$taxon_label == ""]
      gtt$taxon_label <- factor(gtt$taxon_label, levels = rev(unique(gtt$taxon_label)))
      p <- ggplot(gtt, aes(x = taxon_label, y = mean_relative_abundance, fill = .data[[gvar]])) +
        geom_col(position = position_dodge(width = 0.9)) +
        coord_flip() +
        facet_wrap(as.formula(paste("~", gvar)), scales = "free_y") +
        theme_bw() +
        labs(title = "Top Taxa by Group", x = "Taxon", y = "Mean Relative Abundance", fill = gvar)
      fp <- file.path(output_dir, paste0(prefix, "_taxa_by_group_", stamp, ".png"))
      ggsave(fp, p, width = 8, height = 6, dpi = 150)
      out <- c(out, fp)
    }
  }, silent = TRUE)

  out
}

microassist_build_taxa_interaction_network <- function(ps,
                                                       rank = "Genus",
                                                       top_n = 25,
                                                       min_abs_cor = 0.4,
                                                       p_adjust_cutoff = 0.1,
                                                       output_dir = ".",
                                                       prefix = "microassist_integrated") {
  dir.create(output_dir, showWarnings = FALSE, recursive = TRUE)
  stamp <- format(Sys.time(), "%Y%m%d_%H%M%S")

  chosen_rank <- rank
  if (!(chosen_rank %in% phyloseq::rank_names(ps))) {
    chosen_rank <- phyloseq::rank_names(ps)[1]
  }

  ps_rel <- microbiome::transform(ps, "compositional")
  ps_rank <- phyloseq::tax_glom(ps_rel, taxrank = chosen_rank, NArm = FALSE)
  otu_rank <- as(phyloseq::otu_table(ps_rank), "matrix")
  if (!phyloseq::taxa_are_rows(ps_rank)) otu_rank <- t(otu_rank)

  if (nrow(otu_rank) < 3 || ncol(otu_rank) < 4) {
    return(list(edge_table = data.frame(), node_table = data.frame(), figure_file = NULL, rank = chosen_rank))
  }

  taxa_df <- as.data.frame(phyloseq::tax_table(ps_rank))
  mean_abundance <- rowMeans(otu_rank, na.rm = TRUE)
  keep_ids <- names(sort(mean_abundance, decreasing = TRUE))[1:min(top_n, length(mean_abundance))]
  mat <- otu_rank[keep_ids, , drop = FALSE]

  cm <- suppressWarnings(stats::cor(t(mat), method = "spearman", use = "pairwise.complete.obs"))
  n <- ncol(mat)
  if (!is.finite(n) || n < 4) {
    return(list(edge_table = data.frame(), node_table = data.frame(), figure_file = NULL, rank = chosen_rank))
  }
  tval <- abs(cm) * sqrt((n - 2) / pmax(1e-12, (1 - cm^2)))
  pm <- 2 * stats::pt(-abs(tval), df = n - 2)
  pm[lower.tri(pm, diag = TRUE)] <- NA_real_

  idx <- which(!is.na(pm), arr.ind = TRUE)
  if (nrow(idx) == 0) {
    return(list(edge_table = data.frame(), node_table = data.frame(), figure_file = NULL, rank = chosen_rank))
  }
  pvals <- pm[idx]
  padj <- stats::p.adjust(pvals, method = "BH")
  cors <- cm[idx]

  edge_table <- data.frame(
    taxon_1 = rownames(cm)[idx[, 1]],
    taxon_2 = colnames(cm)[idx[, 2]],
    spearman_rho = as.numeric(cors),
    p_value = as.numeric(pvals),
    p_adj = as.numeric(padj),
    stringsAsFactors = FALSE
  )
  edge_table <- edge_table[abs(edge_table$spearman_rho) >= min_abs_cor & edge_table$p_adj <= p_adjust_cutoff, , drop = FALSE]

  node_table <- data.frame(
    taxon_id = keep_ids,
    taxon_label = as.character(taxa_df[keep_ids, chosen_rank, drop = TRUE]),
    mean_relative_abundance = as.numeric(mean_abundance[keep_ids]),
    stringsAsFactors = FALSE
  )

  fig_file <- NULL
  if (nrow(edge_table) > 0) {
    nodes <- unique(c(edge_table$taxon_1, edge_table$taxon_2))
    sub_cor <- cm[nodes, nodes, drop = FALSE]
    dist_mat <- as.dist(1 - abs(sub_cor))
    coords <- cmdscale(dist_mat, k = 2)
    coord_df <- data.frame(taxon_id = rownames(coords), x = coords[, 1], y = coords[, 2], stringsAsFactors = FALSE)
    coord_df <- merge(coord_df, node_table, by = "taxon_id", all.x = TRUE)
    coord_df$taxon_label[is.na(coord_df$taxon_label) | coord_df$taxon_label == ""] <- coord_df$taxon_id[is.na(coord_df$taxon_label) | coord_df$taxon_label == ""]

    edge_plot <- merge(edge_table, coord_df[, c("taxon_id", "x", "y")], by.x = "taxon_1", by.y = "taxon_id", all.x = TRUE)
    edge_plot <- merge(edge_plot, coord_df[, c("taxon_id", "x", "y")], by.x = "taxon_2", by.y = "taxon_id", all.x = TRUE, suffixes = c("_1", "_2"))

    p <- ggplot() +
      geom_segment(data = edge_plot, aes(x = x_1, y = y_1, xend = x_2, yend = y_2, color = spearman_rho, size = abs(spearman_rho)), alpha = 0.6) +
      geom_point(data = coord_df, aes(x = x, y = y, size = mean_relative_abundance), color = "#1f77b4") +
      geom_text(data = coord_df, aes(x = x, y = y, label = taxon_label), vjust = -0.8, size = 3) +
      scale_color_gradient2(low = "#2563eb", high = "#dc2626", mid = "#9ca3af", midpoint = 0) +
      theme_bw() +
      labs(
        title = paste0("Taxa Interaction Network (Data-only, ", chosen_rank, ")"),
        x = "Layout Axis 1",
        y = "Layout Axis 2",
        color = "Spearman rho",
        size = "Magnitude"
      )
    fig_file <- file.path(output_dir, paste0(prefix, "_taxa_network_", stamp, ".png"))
    ggsave(fig_file, p, width = 9, height = 7, dpi = 150)
  }

  list(edge_table = edge_table, node_table = node_table, figure_file = fig_file, rank = chosen_rank)
}

microassist_choose_group_var <- function(meta_df,
                                         requested_group_var = NULL,
                                         priority_candidates = c("COVID19_severity", "primaryTumorType", "SampleType", "sample_type", "group", "Group", "condition", "Condition", "Treatment", "treatment"),
                                         min_non_missing = 3,
                                         min_levels = 2,
                                         max_levels = 20) {
  if (is.null(meta_df) || nrow(meta_df) == 0 || ncol(meta_df) == 0) {
    return(NULL)
  }

  is_valid_group <- function(x) {
    keep <- !is.na(x) & x != ""
    x <- x[keep]
    if (length(x) < min_non_missing) return(FALSE)
    nlev <- length(unique(x))
    nlev >= min_levels && nlev <= max_levels
  }

  if (!is.null(requested_group_var) && requested_group_var %in% colnames(meta_df)) {
    if (is_valid_group(meta_df[[requested_group_var]])) {
      return(requested_group_var)
    }
  }

  for (cand in priority_candidates) {
    if (cand %in% colnames(meta_df) && is_valid_group(meta_df[[cand]])) {
      return(cand)
    }
  }

  for (nm in colnames(meta_df)) {
    x <- meta_df[[nm]]
    if (is.factor(x) || is.character(x) || is.logical(x)) {
      if (is_valid_group(as.character(x))) {
        return(nm)
      }
    }
  }

  NULL
}

microassist_prepare_alpha_input <- function(ps,
                                            integer_tolerance = 1e-8,
                                            round_tolerance = 1e-6) {
  otu_counts <- as(phyloseq::otu_table(ps), "matrix")
  taxa_rows <- phyloseq::taxa_are_rows(ps)
  if (!taxa_rows) {
    otu_counts <- t(otu_counts)
  }

  if (any(!is.finite(otu_counts))) {
    stop("OTU table contains non-finite values (NA/NaN/Inf), which are not valid for alpha diversity.")
  }
  if (any(otu_counts < 0)) {
    stop("OTU table contains negative abundances, which are not valid for alpha diversity.")
  }

  max_delta <- max(abs(otu_counts - round(otu_counts)))
  can_round_to_counts <- is.finite(max_delta) && max_delta <= round_tolerance
  is_integer_counts <- is.finite(max_delta) && max_delta <= integer_tolerance

  alpha_measures <- c("Observed", "Shannon", "Simpson")
  note <- "Using integer count data for alpha diversity."

  ps_for_alpha <- ps
  if (can_round_to_counts) {
    rounded <- round(otu_counts)
    otu_slot <- if (taxa_rows) rounded else t(rounded)
    phyloseq::otu_table(ps_for_alpha) <- phyloseq::otu_table(otu_slot, taxa_are_rows = taxa_rows)
    alpha_measures <- c(alpha_measures, "Chao1", "ACE")
    if (!is_integer_counts) {
      note <- paste0(
        "Counts were near-integers and were rounded (max abs delta=",
        signif(max_delta, 4),
        ") so Chao1/ACE could be computed."
      )
    }
  } else {
    note <- paste0(
      "Detected non-integer abundances (max abs delta=",
      signif(max_delta, 4),
      "). Chao1/ACE were skipped because they require integer counts."
    )
    warning(note, call. = FALSE)
  }

  list(
    ps = ps_for_alpha,
    measures = alpha_measures,
    note = note,
    use_basic_only = !can_round_to_counts,
    otu_counts_taxa_rows = otu_counts
  )
}

microassist_compute_basic_alpha <- function(otu_counts_taxa_rows) {
  if (is.null(dim(otu_counts_taxa_rows)) || ncol(otu_counts_taxa_rows) == 0) {
    stop("OTU table is empty after preprocessing; cannot compute alpha diversity.")
  }

  observed <- colSums(otu_counts_taxa_rows > 0, na.rm = TRUE)
  totals <- colSums(otu_counts_taxa_rows, na.rm = TRUE)

  shannon <- rep(NA_real_, length(totals))
  simpson <- rep(NA_real_, length(totals))

  positive_totals <- totals > 0
  if (any(positive_totals)) {
    idx <- which(positive_totals)
    for (i in idx) {
      p <- otu_counts_taxa_rows[, i] / totals[[i]]
      p <- p[p > 0]
      shannon[[i]] <- -sum(p * log(p))
      simpson[[i]] <- 1 - sum(p^2)
    }
  }

  out <- data.frame(
    Observed = as.numeric(observed),
    Shannon = as.numeric(shannon),
    Simpson = as.numeric(simpson),
    stringsAsFactors = FALSE
  )
  rownames(out) <- colnames(otu_counts_taxa_rows)
  out
}

# ------------------------------------------------------------------
# Agent 2: Alpha Diversity Insights
# ------------------------------------------------------------------

microassist_alpha_diversity_agent <- function(ps,
                                              experimental_context,
                                              group_var = NULL,
                                              google_api_key = NULL,
                                              api_key_file = "~/Documents/gemini_api_key_copy.txt",
                                              model_name = "gemini-flash-latest",
                                              temperature = 0,
                                              max_output_tokens = 8192,
                                              llm_max_retries = 3,
                                              llm_retry_padding_seconds = 2,
                                              llm_fallback_models = c("gemini-1.5-flash-latest")) {
  if (!inherits(ps, "phyloseq")) stop("Input 'ps' must be a phyloseq object.")
  if (is.null(experimental_context) || nchar(experimental_context) == 0) {
    stop("Input 'experimental_context' must be a non-empty character string.")
  }

  api_key <- microassist_get_api_key(google_api_key, api_key_file)

  alpha_input <- microassist_prepare_alpha_input(ps)
  alpha_df <- if (isTRUE(alpha_input$use_basic_only)) {
    alpha_input$note <- paste(
      alpha_input$note,
      "Using direct computation for Observed/Shannon/Simpson to avoid integer-only estimators.",
      sep = " "
    )
    microassist_compute_basic_alpha(alpha_input$otu_counts_taxa_rows)
  } else {
    tryCatch(
      phyloseq::estimate_richness(alpha_input$ps, measures = alpha_input$measures),
      error = function(e) {
        err_msg <- conditionMessage(e)
        integer_error <- grepl("function accepts only integers \\(counts\\)", err_msg, ignore.case = TRUE)
        if (!integer_error) {
          stop(e)
        }

        alpha_input$note <<- paste(
          alpha_input$note,
          "estimate_richness raised an integer-count error; falling back to direct Observed/Shannon/Simpson computation.",
          sep = " "
        )
        warning(alpha_input$note, call. = FALSE)

        microassist_compute_basic_alpha(alpha_input$otu_counts_taxa_rows)
      }
    )
  }
  
  meta_df <- as.data.frame(sample_data(ps))

  selected_group_var <- microassist_choose_group_var(meta_df, requested_group_var = group_var)

  group_summary <- "No valid grouping variable available for alpha diversity grouping."
  if (!is.null(selected_group_var)) {
    alpha_df[[selected_group_var]] <- meta_df[[selected_group_var]]
    metrics <- intersect(c("Observed", "Shannon", "Simpson", "Chao1", "ACE"), colnames(alpha_df))
    stats_by_group <- alpha_df %>%
      dplyr::group_by(.data[[selected_group_var]]) %>%
      dplyr::summarise(
        n = dplyr::n(),
        across(dplyr::all_of(metrics), ~mean(.x, na.rm = TRUE), .names = "{.col}_mean"),
        .groups = "drop"
      )
    group_summary <- paste(capture.output(print(stats_by_group)), collapse = "\n")
  }

  prompt <- paste0(
    "You are a microbiome diversity expert. Interpret alpha diversity biologically. ",
    "Return markdown ONLY with the exact headers:\n\n",
    "### Alpha Diversity Interpretation\n\n",
    "### Group-Level Biological Context\n\n",
    "### Mechanistic Hypotheses\n\n",
    "Context:\n", experimental_context, "\n\n",
    "Alpha-metric note: ", alpha_input$note, "\n\n",
    "Alpha diversity summary (Observed, Shannon, Simpson, Chao1, ACE):\n", paste(capture.output(summary(alpha_df)), collapse = "\n"), "\n\n",
    "Group summary:\n", group_summary, "\n"
  )

  headers <- c("Alpha Diversity Interpretation", "Group-Level Biological Context", "Mechanistic Hypotheses")
  llm_input_files <- microassist_write_intermediate_results(
    prefix = "microassist_alpha_input",
    named_objects = list(
      experimental_context = experimental_context,
      alpha_metric_note = alpha_input$note,
      alpha_metrics = alpha_df,
      group_summary = group_summary
    )
  )
  sections <- microassist_safe_llm_sections(
    prompt, headers, api_key, model_name, temperature, max_output_tokens,
    max_retries = llm_max_retries,
    retry_padding_seconds = llm_retry_padding_seconds,
    fallback_models = llm_fallback_models
  )
  report_file <- microassist_write_report("microassist_alpha_diversity_insights", experimental_context, sections)

  list(
    agent = "alpha_diversity",
    sections = sections,
    alpha_metrics = alpha_df,
    alpha_metric_note = alpha_input$note,
    grouping_variable = selected_group_var,
    llm_input_files = llm_input_files,
    report_file = report_file
  )
}

