microassist_beta_diversity_agent <- function(ps,
                                             experimental_context,
                                             group_var = NULL,
                                             distance_method = "bray",
                                             google_api_key = NULL,
                                             api_key_file = "~/Documents/gemini_api_key_copy.txt",
                                             model_name = "gemini-flash-latest",
                                             temperature = 0,
                                             max_output_tokens = 8192,
                                             llm_max_retries = 3,
                                             llm_retry_padding_seconds = 2,
                                             llm_fallback_models = c("gemini-1.5-flash-latest")) {
  if (!inherits(ps, "phyloseq")) stop("Input 'ps' must be a phyloseq object.")
  if (is.null(experimental_context) || nchar(experimental_context) == 0) {
    stop("Input 'experimental_context' must be a non-empty character string.")
  }

  api_key <- microassist_get_api_key(google_api_key, api_key_file)

  dist_obj <- phyloseq::distance(ps, method = distance_method)
  ord <- phyloseq::ordinate(ps, method = "PCoA", distance = dist_obj)

  otu <- as(otu_table(ps), "matrix")
  if (!taxa_are_rows(ps)) otu <- t(otu)
  taxa_variance <- apply(otu, 1, var)
  top_taxa <- sort(taxa_variance, decreasing = TRUE)[1:min(20, length(taxa_variance))]

  meta_df <- as.data.frame(sample_data(ps))
  selected_group_var <- microassist_choose_group_var(meta_df, requested_group_var = group_var)

  group_values <- NULL
  group_line <- if (!is.null(selected_group_var)) {
    group_values <- meta_df[[selected_group_var]]
    names(group_values) <- rownames(meta_df)
    paste0("Grouping variable: ", selected_group_var, "; Levels: ", paste(unique(meta_df[[selected_group_var]]), collapse = ", "))
  } else {
    "No valid grouping variable available for beta diversity grouping."
  }

  eig <- ord$values$Eigenvalues
  eig_preview <- if (!is.null(eig) && length(eig) > 0) round(eig[1:min(3, length(eig))], 6) else NA

  dvals <- as.numeric(dist_obj)
  dist_stats <- c(
    min = min(dvals, na.rm = TRUE),
    q25 = as.numeric(quantile(dvals, 0.25, na.rm = TRUE)),
    median = median(dvals, na.rm = TRUE),
    mean = mean(dvals, na.rm = TRUE),
    q75 = as.numeric(quantile(dvals, 0.75, na.rm = TRUE)),
    max = max(dvals, na.rm = TRUE)
  )

  top_taxa_small <- round(top_taxa[1:min(10, length(top_taxa))], 6)

  prompt <- paste0(
    "You are a microbiome community ecology expert. Interpret beta diversity patterns and potential drivers. ",
    "Return markdown ONLY with the exact headers:\n\n",
    "### Community Similarity and Separation\n\n",
    "### Likely Drivers (Taxa or Functions)\n\n",
    "### Community-Structure Hypotheses\n\n",
    "Context: ", experimental_context, "\n",
    group_line, "\n",
    "Distance stats (", distance_method, "): ",
    paste(names(round(dist_stats, 5)), round(dist_stats, 5), collapse = "; "), "\n",
    "Top PCoA eigenvalues: ", paste(eig_preview, collapse = ", "), "\n",
    "Top variable taxa (top 10 variance): ",
    paste(names(top_taxa_small), top_taxa_small, collapse = "; "), "\n"
  )

  headers <- c("Community Similarity and Separation", "Likely Drivers (Taxa or Functions)", "Community-Structure Hypotheses")
  llm_input_files <- microassist_write_intermediate_results(
    prefix = "microassist_beta_input",
    named_objects = list(
      experimental_context = experimental_context,
      group_line = group_line,
      distance_stats = as.data.frame(t(round(dist_stats, 6))),
      top_eigenvalues = data.frame(eigenvalue = as.numeric(eig_preview)),
      top_variable_taxa = data.frame(taxon_id = names(top_taxa_small), variance = as.numeric(top_taxa_small), stringsAsFactors = FALSE),
      distance_matrix = dist_obj
    )
  )
  sections <- microassist_safe_llm_sections(
    prompt, headers, api_key, model_name, temperature, max_output_tokens,
    max_retries = llm_max_retries,
    retry_padding_seconds = llm_retry_padding_seconds,
    fallback_models = llm_fallback_models
  )
  report_file <- microassist_write_report("microassist_beta_diversity_insights", experimental_context, sections)

  list(
    agent = "beta_diversity",
    sections = sections,
    distance_method = distance_method,
    distance = dist_obj,
    ordination = ord,
    group_values = group_values,
    top_variable_taxa = top_taxa,
    llm_input_files = llm_input_files,
    report_file = report_file
  )
}

