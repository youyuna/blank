  previous_report_sections <- microassist_build_previous_report_sections(
    preprocessing_result = preprocessing_result,
    alpha_result = alpha_result,
    beta_result = beta_result,
    taxonomic_result = taxonomic_result,
    preprocessing_report_file = preprocessing_report_file
  )
  
  session_info_text <- paste(capture.output(sessionInfo()), collapse = "\n")
  combined_sections <- c(sections, previous_report_sections, list("sessionInfo()" = session_info_text))

  report_file_txt <- microassist_write_report("microassist_integrated_analysis_report", experimental_context, combined_sections)

  figure_paths <- microassist_generate_integrated_figures(
    alpha_result = alpha_result,
    beta_result = beta_result,
    taxonomic_result = taxonomic_result,
    output_dir = figure_output_dir,
    prefix = "microassist_integrated"
  )

  network <- microassist_build_taxa_interaction_network(
    ps = taxonomic_result$ps_input,
    rank = taxonomic_result$rank_used,
    output_dir = figure_output_dir,
    prefix = "microassist_integrated"
  )
  if (!is.null(network$figure_file) && file.exists(network$figure_file)) {
    figure_paths <- c(figure_paths, network$figure_file)
  }

  network_files <- microassist_write_intermediate_results(
    prefix = "microassist_network",
    named_objects = list(
      network_rank = network$rank,
      node_table = network$node_table,
      edge_table = network$edge_table
    ),
    output_dir = figure_output_dir
  )

  report_title <- trimws(sections[["Report Title"]])
  if (is.null(report_title) || nchar(report_title) == 0 || grepl("^LLM call failed", report_title)) {
    report_title <- "Integrated Microbiome Analysis Report"
  }

  report_file_html <- microassist_write_html_report(
    prefix = "microassist_integrated_analysis_report",
    context = experimental_context,
    sections = combined_sections,
    figure_paths = figure_paths,
    report_title = report_title
  )

  list(
    agent = "integrated_report",
    sections = sections,
    embedded_agent_reports = previous_report_sections,
    llm_input_files = llm_input_files,
    network = network,
    network_files = network_files,
    report_file = report_file_txt,
    report_file_html = report_file_html,
    figure_files = figure_paths
  )
}

