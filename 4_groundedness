# Groundedness assessment (microbiome-focused)
# This is intentionally a separate chunk and does not modify prior chunks.

if (!requireNamespace("pheatmap", quietly = TRUE)) {
  stop("Package 'pheatmap' is required for heatmap plotting. Install with install.packages('pheatmap').")
}

# Build groundedness inputs directly from objects already created in this workflow:
# 1) original_microbe_list_from_phyloseq
# 2) integrated_report_microbe_list
#
# This avoids external file dependencies and uses your in-memory phyloseq + report outputs.

if (!exists("ps_example")) {
  stop("Object 'ps_example' was not found. Run preprocessing / setup chunk first.")
}
if (!exists("out")) {
  stop("Object 'out' was not found. Run the runagents pipeline first so integrated report outputs exist.")
}

# Rank preference for this groundedness check:
# - force Phylum-level if available
# - else fall back to first available rank
available_ranks <- phyloseq::rank_names(ps_example)
preferred_rank <- if ("Phylum" %in% available_ranks) "Phylum" else if ("phylum" %in% available_ranks) "phylum" else available_ranks[[1]]

tax_df <- as.data.frame(phyloseq::tax_table(ps_example))
normalize_taxon <- function(x) {
  x <- trimws(as.character(x))
  x <- gsub("^['\"`]|['\"`]$", "", x)
  x <- gsub("^[Pp]__+", "", x) # remove p__ prefixes
  x <- gsub("[^A-Za-z0-9_-]", "", x)
  x <- tolower(x)
  x
}

original_microbe_list_from_phyloseq_raw <- unique(trimws(as.character(tax_df[[preferred_rank]])))
original_microbe_list_from_phyloseq_raw <- original_microbe_list_from_phyloseq_raw[
  !is.na(original_microbe_list_from_phyloseq_raw) &
    original_microbe_list_from_phyloseq_raw != "" &
    original_microbe_list_from_phyloseq_raw != "NA"
]
reference_list <- sort(unique(normalize_taxon(original_microbe_list_from_phyloseq_raw)))
reference_list <- reference_list[reference_list != ""]

# Gather all integrated-report text blocks and detect mentioned microbes by exact string match
integrated_sections <- unlist(out$integrated_result$sections, use.names = FALSE)
embedded_sections <- unlist(out$integrated_result$embedded_agent_reports, use.names = FALSE)
all_integrated_text <- paste(c(integrated_sections, embedded_sections), collapse = "\n\n")

# Extract phylum-like tokens from report text (not limited to the reference list)
extract_report_phyla <- function(text_blob) {
  # Candidate words with phylum-like suffixes in microbiome reports
  rx <- "\\b([A-Za-z][A-Za-z0-9_-]{2,}(?:bacteria|ota|mycota|archaeota))\\b"
  m <- regmatches(text_blob, gregexpr(rx, text_blob, perl = TRUE, ignore.case = TRUE))
  raw <- if (length(m) > 0) unlist(m, use.names = FALSE) else character(0)

  # Also catch explicit p__Phylum labels if present
  rx_pref <- "\\bp__([A-Za-z][A-Za-z0-9_-]{2,})\\b"
  m_pref <- regmatches(text_blob, gregexpr(rx_pref, text_blob, perl = TRUE, ignore.case = TRUE))
  raw_pref <- if (length(m_pref) > 0) gsub("^[Pp]__+", "", unlist(m_pref, use.names = FALSE)) else character(0)

  sort(unique(normalize_taxon(c(raw, raw_pref))))
}

report_phyla_all <- extract_report_phyla(all_integrated_text)

# Keep a reference-constrained list too, for direct overlap accounting
integrated_report_microbe_list <- sort(unique(intersect(report_phyla_all, reference_list)))
integrated_report_microbe_list_all_mentions <- report_phyla_all

# Keep two explicit objects requested by user
reference_name <- "original_microbe_list_from_phyloseq"
experiment_lists <- list(integrated_report_microbe_list = integrated_report_microbe_list)
if (length(integrated_report_microbe_list_all_mentions) > 0) {
  experiment_lists[["integrated_report_microbe_list_all_mentions"]] <- integrated_report_microbe_list_all_mentions
}

print(paste("Selected taxonomic rank for original list:", preferred_rank))
print(paste("Original microbe list size:", length(reference_list)))
print(paste("Integrated report microbe list size:", length(integrated_report_microbe_list)))
print(paste("Integrated report phylum mentions (all) size:", length(integrated_report_microbe_list_all_mentions)))


# Function to calculate overlap, unique taxa, groundedness score, and unique taxa list
calculate_overlap_and_unique_microbes <- function(reference_list, experiment_list) {
  overlap <- length(intersect(reference_list, experiment_list))
  unique_taxa <- length(setdiff(experiment_list, reference_list))
  groundedness_score <- if ((overlap + unique_taxa) == 0) {
    NA_real_
  } else {
    (overlap / (overlap + unique_taxa)) * 100
  }
  unique_taxa_list <- setdiff(experiment_list, reference_list)

  list(
    Overlap = overlap,
    UniqueTaxa = unique_taxa,
    GroundednessScore = groundedness_score,
    UniqueTaxaList = unique_taxa_list
  )
}

# Calculate overlap between reference list and each experiment list
reference_results <- lapply(
  experiment_lists,
  function(x) calculate_overlap_and_unique_microbes(reference_list, x)
)

print(paste("Reference microbiome list:", reference_name))
print("Overlap and Unique Taxa between Reference List and each Experiment List:")
reference_overlaps <- data.frame(
  ExperimentList = names(experiment_lists),
  Overlap = sapply(reference_results, function(x) x$Overlap),
  UniqueTaxa = sapply(reference_results, function(x) x$UniqueTaxa),
  GroundednessScore = round(sapply(reference_results, function(x) x$GroundednessScore), 2),
  stringsAsFactors = FALSE
)
print(reference_overlaps)

# Store unique taxa lists
unique_taxa_lists <- lapply(reference_results, function(x) x$UniqueTaxaList)
names(unique_taxa_lists) <- names(experiment_lists)

# Print unique taxa lists
for (i in seq_along(unique_taxa_lists)) {
  print(paste("Unique taxa for", names(unique_taxa_lists)[i]))
  print(unique_taxa_lists[[i]])
}

# Pairwise overlap between each pair of experiment lists
n <- length(experiment_lists)
experiment_overlaps <- matrix(0, nrow = n, ncol = n)

for (i in seq_len(n)) {
  for (j in seq_len(n)) {
    if (i == j) {
      experiment_overlaps[i, j] <- length(experiment_lists[[i]])
    } else if (i < j) {
      overlap <- length(intersect(experiment_lists[[i]], experiment_lists[[j]]))
      experiment_overlaps[i, j] <- overlap
      experiment_overlaps[j, i] <- overlap
    }
  }
}

# Percent overlap using max list size from each pair as denominator
denom_mat <- outer(
  seq_len(n),
  seq_len(n),
  Vectorize(function(i, j) max(length(experiment_lists[[i]]), length(experiment_lists[[j]]), 1))
)
experiment_percent_overlap <- round((experiment_overlaps / denom_mat) * 100)
diag(experiment_percent_overlap) <- 100

rownames(experiment_percent_overlap) <- names(experiment_lists)
colnames(experiment_percent_overlap) <- names(experiment_lists)

# Visualize matrix as heatmap with percentage labels (only when informative)
if (n > 1 && length(unique(as.vector(experiment_percent_overlap))) > 1) {
  pheatmap::pheatmap(
    experiment_percent_overlap,
    cluster_rows = FALSE,
    cluster_cols = FALSE,
    show_rownames = TRUE,
    show_colnames = TRUE,
    main = "Percent Overlap Between Experiment Microbiome Lists",
    color = colorRampPalette(c("blue", "red"))(100),
    display_numbers = experiment_percent_overlap,
    number_format = "%d",
    number_color = "white"
  )
} else {
  print("Heatmap skipped: need >=2 experiment lists with non-constant overlap values.")
  print(experiment_percent_overlap)
}

print("Overlap between each pair of Experiment Lists:")
if (n > 1) {
  for (i in 1:(n - 1)) {
    for (j in (i + 1):n) {
      print(paste(
        names(experiment_lists)[i], "vs", names(experiment_lists)[j],
        ": overlap =", experiment_overlaps[i, j]
      ))
    }
  }
} else {
  print("Only one experiment list supplied (integrated_report_microbe_list); pairwise comparison skipped.")
}
