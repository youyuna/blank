# --- Shared Helpers ---

microassist_get_api_key <- function(google_api_key = NULL,
                                    api_key_file = "/Users/data/api_keys.txt") {
  if (!is.null(api_key_file)) {
    if (!file.exists(api_key_file)) {
      stop("API key file '", api_key_file, "' not found. Please provide a valid path.")
    }
    api_key <- readLines(api_key_file, n = 1, warn = FALSE)
    if (nchar(api_key) == 0) {
      stop("API key file '", api_key_file, "' is empty.")
    }
    return(api_key)
  }

  if (!is.null(google_api_key) && nchar(google_api_key) > 0) {
    return(google_api_key)
  }

  stop("Either 'google_api_key' or 'api_key_file' must be provided.")
}

microassist_call_gemini <- function(prompt_text,
                                    api_key,
                                    model_name = "gemini-1.5-flash-latest",
                                    temperature = 0,
                                    max_output_tokens = 8192) {
  api_endpoint_url <- paste0(
    "https://generativelanguage.googleapis.com/v1beta/models/",
    model_name,
    ":generateContent"
  )

  request_body <- list(
    contents = list(list(parts = list(list(text = prompt_text)))),
    generationConfig = list(
      temperature = temperature,
      maxOutputTokens = max_output_tokens
    )
  )

  response <- tryCatch({
    httr::POST(
      url = api_endpoint_url,
      httr::add_headers(.headers = c("Content-Type" = "application/json")),
      query = list(key = api_key),
      body = RJSONIO::toJSON(request_body, auto_unbox = TRUE),
      encode = "json"
    )
  }, error = function(e) {
    stop("Google Gemini API call failed: ", e$message, call. = FALSE)
  })

  if (httr::http_error(response)) {
    response_text <- httr::content(response, "text")
    stop(
      paste0(
        "Google Gemini API request failed with status ",
        httr::status_code(response),
        ". Response: ",
        response_text
      ),
      call. = FALSE
    )
  }

  response_content <- httr::content(response, "parsed")
  if (is.null(response_content$candidates) || length(response_content$candidates) == 0) {
    stop("No valid candidates found in LLM response.", call. = FALSE)
  }

  parts <- response_content$candidates[[1]]$content$parts
  if (is.null(parts) || length(parts) == 0) {
    stop("LLM response candidates found, but content/parts are missing.", call. = FALSE)
  }

  part_texts <- sapply(parts, function(part) if (!is.null(part$text)) part$text else NA_character_)
  llm_raw_response_text <- paste(na.omit(part_texts), collapse = "\n")

  if (nchar(llm_raw_response_text) == 0) {
    stop("LLM response was received but contained no extractable text.", call. = FALSE)
  }

  llm_raw_response_text
}

microassist_extract_sections <- function(text, headers) {
  sections <- list()
  for (i in seq_along(headers)) {
    this_header <- headers[[i]]
    next_header <- if (i < length(headers)) headers[[i + 1]] else NULL

    if (is.null(next_header)) {
      pattern <- paste0("(?s)### ", this_header, "\\n\\n(.*)$")
    } else {
      pattern <- paste0("(?s)### ", this_header, "\\n\\n(.*?)(?:\\n\\n### ", next_header, "|$)")
    }

    m <- regmatches(text, regexec(pattern, text, perl = TRUE, ignore.case = TRUE))
    if (length(m) > 0 && length(m[[1]]) > 1) {
      sections[[this_header]] <- trimws(m[[1]][2])
    } else {
      sections[[this_header]] <- paste0("Error: Could not extract '", this_header, "' section.")
    }
  }
  sections
}

microassist_save_report <- function(prefix, context, body_text) {
  timestamp_str <- format(Sys.time(), "%Y%m%d_%H%M%S")
  filename <- paste0(prefix, "_", timestamp_str, ".txt")

  full_text <- paste0(
    "Timestamp: ", format(Sys.time(), "%Y-%m-%d %H:%M:%S"), "\n\n",
    "--- Experimental Context ---\n", context, "\n\n",
    body_text, "\n"
  )

  writeLines(full_text, filename)
  message("Saved report: ", filename)
  filename
}

microassist_choose_group_var <- function(meta_df,
                                         requested_group_var = NULL,
                                         priority_candidates = c("COVID19_severity", "primaryTumorType", "SampleType", "sample_type", "group", "Group", "condition", "Condition", "Treatment", "treatment"),
                                         min_non_missing = 3,
                                         min_levels = 2,
                                         max_levels = 20) {
  if (is.null(meta_df) || nrow(meta_df) == 0 || ncol(meta_df) == 0) {
    return(NULL)
  }

  is_valid_group <- function(x) {
    keep <- !is.na(x) & x != ""
    x <- x[keep]
    if (length(x) < min_non_missing) return(FALSE)
    nlev <- length(unique(x))
    nlev >= min_levels && nlev <= max_levels
  }

  if (!is.null(requested_group_var) && requested_group_var %in% colnames(meta_df)) {
    if (is_valid_group(meta_df[[requested_group_var]])) return(requested_group_var)
  }

  for (cand in priority_candidates) {
    if (cand %in% colnames(meta_df) && is_valid_group(meta_df[[cand]])) return(cand)
  }

  for (nm in colnames(meta_df)) {
    x <- meta_df[[nm]]
    if (is.factor(x) || is.character(x) || is.logical(x)) {
      if (is_valid_group(as.character(x))) return(nm)
    }
  }

  NULL
}

microassist_prepare_alpha_input <- function(ps,
                                            integer_tolerance = 1e-8,
                                            round_tolerance = 1e-6) {
  otu_counts <- as(phyloseq::otu_table(ps), "matrix")
  taxa_rows <- phyloseq::taxa_are_rows(ps)
  if (!taxa_rows) {
    otu_counts <- t(otu_counts)
  }

  if (any(!is.finite(otu_counts))) {
    stop("OTU table contains non-finite values (NA/NaN/Inf), which are not valid for alpha diversity.")
  }
  if (any(otu_counts < 0)) {
    stop("OTU table contains negative abundances, which are not valid for alpha diversity.")
  }

  max_delta <- max(abs(otu_counts - round(otu_counts)))
  can_round_to_counts <- is.finite(max_delta) && max_delta <= round_tolerance
  is_integer_counts <- is.finite(max_delta) && max_delta <= integer_tolerance

  alpha_measures <- c("Observed", "Shannon", "Simpson")
  note <- "Using integer count data for alpha diversity."

  ps_for_alpha <- ps
  if (can_round_to_counts) {
    rounded <- round(otu_counts)
    otu_slot <- if (taxa_rows) rounded else t(rounded)
    phyloseq::otu_table(ps_for_alpha) <- phyloseq::otu_table(otu_slot, taxa_are_rows = taxa_rows)
    alpha_measures <- c(alpha_measures, "Chao1", "ACE")
    if (!is_integer_counts) {
      note <- paste0(
        "Counts were near-integers and were rounded (max abs delta=",
        signif(max_delta, 4),
        ") so Chao1/ACE could be computed."
      )
    }
  } else {
    note <- paste0(
      "Detected non-integer abundances (max abs delta=",
      signif(max_delta, 4),
      "). Chao1/ACE were skipped because they require integer counts."
    )
    warning(note, call. = FALSE)
  }

  list(
    ps = ps_for_alpha,
    measures = alpha_measures,
    note = note,
    use_basic_only = !can_round_to_counts,
    otu_counts_taxa_rows = otu_counts
  )
}

microassist_compute_basic_alpha <- function(otu_counts_taxa_rows) {
  if (is.null(dim(otu_counts_taxa_rows)) || ncol(otu_counts_taxa_rows) == 0) {
    stop("OTU table is empty after preprocessing; cannot compute alpha diversity.")
  }

  observed <- colSums(otu_counts_taxa_rows > 0, na.rm = TRUE)
  totals <- colSums(otu_counts_taxa_rows, na.rm = TRUE)

  shannon <- rep(NA_real_, length(totals))
  simpson <- rep(NA_real_, length(totals))

  positive_totals <- totals > 0
  if (any(positive_totals)) {
    idx <- which(positive_totals)
    for (i in idx) {
      p <- otu_counts_taxa_rows[, i] / totals[[i]]
      p <- p[p > 0]
      shannon[[i]] <- -sum(p * log(p))
      simpson[[i]] <- 1 - sum(p^2)
    }
  }

  out <- data.frame(
    Observed = as.numeric(observed),
    Shannon = as.numeric(shannon),
    Simpson = as.numeric(simpson),
    stringsAsFactors = FALSE
  )
  rownames(out) <- colnames(otu_counts_taxa_rows)
  out
}



